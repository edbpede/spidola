<!--
  Every user-facing string in the playback slice (PRD §6.10: English-first, string infrastructure
  ready from day one), in PRD §8.6 voice: from the couch, active, engine-neutral — "Try other
  player", never "ExoPlayer failed"; the viewer never learns which decoder is running.

  Two absences are deliberate. The actionable-error vocabulary — a failure's class, its message, and
  the "Try again" / "Go back" that answer it — is not here: `PlaybackErrorView` renders all three
  from `EngineError`, so resourcing the buttons alone would translate the answer and leave the
  question English. The shells take that vocabulary over as a code-plus-data contract in its own
  change; until then it stays wholly unextracted so no one mistakes it for finished. The fallback
  offer's own buttons below are not that vocabulary — they are plain labels this slice writes.
-->
<resources>

    <!-- Tuning -->
    <string name="playback_tuning">Tuning…</string>

    <!-- The strip, and what a screen reader hears in place of the video (PRD §8.5). -->
    <string name="playback_now_playing">Playing %1$s. Press up or down to change channel.</string>
    <!-- The live badge on the band: set in capitals as a broadcast marker. -->
    <string name="playback_live_marker">LIVE</string>
    <!-- The same fact, spoken rather than shown, as one clause of the strip's announcement. -->
    <string name="playback_live_announcement">Live</string>
    <!-- The playing channel's place in the zap ring, e.g. "3 / 40". -->
    <string name="playback_position">%1$d / %2$d</string>

    <!-- Options: audio, subtitles, picture (PRD §8.4) -->
    <string name="playback_options_audio">Audio</string>
    <string name="playback_options_subtitles">Subtitles</string>
    <string name="playback_options_picture">Picture</string>
    <string name="playback_options_subtitles_off">Off</string>
    <string name="playback_options_single_audio">Only one audio track</string>
    <!--
      Spoken in place of the check mark on the track in use (PRD §6.10). The picture row cycles rather
      than chooses, so it is never marked and never says this.
    -->
    <string name="playback_options_selected">Selected</string>
    <!-- A track that carries both a name and a language, e.g. "Commentary · English". -->
    <string name="playback_track_label">%1$s · %2$s</string>

    <!--
      The aspect modes, spelled out again here rather than read from `player-contract`'s
      AspectMode.label: a label baked into a contract class cannot be translated (PRD §6.10). Same
      posture as the settings slice takes with the buffering profiles.
    -->
    <string name="playback_aspect_fit">Fit</string>
    <string name="playback_aspect_fill">Fill</string>
    <string name="playback_aspect_stretch">Stretch</string>

    <!-- The loud fallback (TECH_SPEC §8): the viewer is offered the swap and chooses. -->
    <string name="playback_fallback_try_other">Try other player</string>
    <string name="playback_fallback_remember">Remember for this channel</string>
    <string name="playback_fallback_once">Just this once</string>
    <string name="playback_fallback_back">Go back</string>

    <!-- Left/right on a stream that cannot seek: "no-op with hint" (PRD §8.4). -->
    <string name="playback_seek_hint">This channel is live — there\'s nothing to skip to.</string>

</resources>

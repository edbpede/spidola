#
# Copy to signing.env (ignored), fill locally, then `set -a; source signing.env; set +a`.
# CI supplies the same values from repository secrets. Never commit a populated copy.
SPIDOLA_ANDROID_KEYSTORE=/absolute/path/to/spidola-release.jks
SPIDOLA_ANDROID_STORE_PASSWORD=
SPIDOLA_ANDROID_KEY_ALIAS=
SPIDOLA_ANDROID_KEY_PASSWORD=

{
  "sourceLanguage": "en",
  "strings": {
    "%@, %@": {
      "comment": "Screen-reader label for a channel row: its name, then its group. Both values come from the channel. Reorder with %1$@ and %2$@ where the language wants them the other way round.",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@, %2$@"
          }
        }
      }
    },
